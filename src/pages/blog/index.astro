---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="yyyyang | Blog"
  description="yyyyang 的博客列表，包含文章、笔记、复盘和长期思考。"
>
  <Fragment slot="hero">
    <div class="hero-grid hero-grid-blog">
      <div class="hero-copy hero-copy-blog">
        <p class="eyebrow">Blog / Writing</p>
        <h1>写作会成为这个站点的第二主入口。</h1>
        <p class="lead">
          这里会逐步承载建站记录、工程实践、工具体验和阶段性思考。文章从 Markdown 生成，结构稳定，后续只需要持续写内容。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/">返回主页</a>
          <a class="button button-secondary" href="/docs/blog/">博客规范</a>
        </div>
      </div>

      <div class="hero-stack">
        <article class="hero-card hero-card-strong">
          <span class="mini-label">Writing Flow</span>
          <h2>写 Markdown，站点自动生成页面。</h2>
          <p>后续你只需要新增文章文件，博客列表和详情页就会自动渲染出来。</p>
        </article>
      </div>
    </div>
  </Fragment>

  <section class="panel panel-clean">
    <div class="section-heading">
      <p class="eyebrow">Posts</p>
      <h2>最新文章</h2>
    </div>
    <div class="blog-feed">
      {
        posts.map((post, index) => (
          <article class={`blog-card blog-card-feature ${index === 0 ? "blog-card-primary" : ""}`}>
            <p class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</p>
            <h3>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div class="blog-card-footer">
              <span class="chip">Post</span>
              <a class="text-link" href={`/blog/${post.id}/`}>阅读全文</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
