---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: post,
    }));
}

const post = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | yyyyang`} description={post.data.description}>
  <Fragment slot="hero">
    <div class="hero-grid hero-grid-blog">
      <div class="hero-copy hero-copy-blog">
        <p class="eyebrow">Blog Post</p>
        <h1>{post.data.title}</h1>
        <p class="lead">{post.data.description}</p>
      </div>

      <div class="hero-stack">
        <article class="hero-card hero-card-soft">
          <span class="mini-label">Published</span>
          <h2>{post.data.pubDate.toISOString().slice(0, 10)}</h2>
          <p>
            <a class="text-link" href="/blog/">返回博客列表</a>
          </p>
        </article>
      </div>
    </div>
  </Fragment>

  <article class="panel prose-panel panel-clean">
    <Content />
  </article>
</BaseLayout>
