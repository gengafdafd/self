---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="yyyyang | Personal Site"
  description="yyyyang 的个人主页，展示个人介绍、方向、项目入口和长期积累。"
>
  <Fragment slot="hero">
    <div class="hero-grid hero-grid-home">
      <div class="hero-copy hero-copy-home">
        <p class="eyebrow">Personal Site / Notes / Projects</p>
        <div class="intro-pill">Independent site for profile, writing and projects</div>
        <h1>一个更稳定、更像自己的个人主页。</h1>
        <p class="lead">
          这里是 yyyyang 的公开入口。个人介绍、项目、博客和阶段性积累，会在这里被整理成更清晰、更稳定、也更有个人气质的内容结构。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/blog/">进入博客</a>
          <a class="button button-secondary" href="/docs/about/personal-profile/">查看介绍</a>
        </div>
      </div>

      <div class="hero-stack">
        <article class="hero-card hero-card-strong">
          <span class="mini-label">Current Focus</span>
          <h2>主页先做品牌感，博客负责持续生长。</h2>
          <p>先把信息入口、视觉秩序和内容节奏打稳，再逐步长出项目、文章和长期记录。</p>
        </article>

        <article class="hero-card hero-card-soft">
          <span class="mini-label">Now Building</span>
          <ul class="bullet-list">
            <li>个人主页</li>
            <li>博客系统</li>
            <li>文档入口</li>
          </ul>
        </article>
      </div>
    </div>
  </Fragment>

  <section class="panel metrics-panel panel-ghost">
    <div class="metrics-grid">
      <article class="metric-item">
        <span>Identity</span>
        <strong>Personal Home</strong>
      </article>
      <article class="metric-item">
        <span>Writing</span>
        <strong>Astro Blog</strong>
      </article>
      <article class="metric-item">
        <span>Publishing</span>
        <strong>GitHub Pages</strong>
      </article>
    </div>
  </section>

  <section class="panel panel-clean">
    <div class="section-heading">
      <p class="eyebrow">Overview</p>
      <h2>首页只保留三件事：你是谁、你在做什么、内容从哪里进入。</h2>
    </div>
    <div class="grid overview-grid">
      <article class="card card-large">
        <p class="quote-mark">About</p>
        <h3>一个长期维护的个人入口</h3>
        <p>不是简历页，也不是随手搭的链接树，而是一个持续沉淀个人表达、项目和写作的地方。</p>
      </article>
      <article class="card">
        <p class="quote-mark">Direction</p>
        <h3>当前方向</h3>
        <p>先把整体观感和内容架构稳定下来，再逐步填充真实项目和文章。</p>
      </article>
      <article class="card">
        <p class="quote-mark">Writing</p>
        <h3>博客会成为第二主入口</h3>
        <p>后续文章会覆盖建站记录、工程实践、AI 使用经验和阶段性思考。</p>
      </article>
    </div>
  </section>

  <section class="panel accent panel-showcase">
    <div class="section-heading">
      <p class="eyebrow">Sections</p>
      <h2>两个入口，各自负责不同的信息密度。</h2>
    </div>
    <div class="grid split-grid showcase-grid">
      <article class="card showcase-card">
        <span class="tag">Home</span>
        <h3>个人主页</h3>
        <p>承载定位、对外介绍、个人链接和重点内容，偏展示和识别度。</p>
        <a class="text-link" href="/docs/about/personal-profile/">进入介绍</a>
      </article>
      <article class="card showcase-card">
        <span class="tag">Blog</span>
        <h3>博客</h3>
        <p>承载文章、笔记、复盘和长期思考，偏内容沉淀和持续更新。</p>
        <a class="text-link" href="/blog/">进入博客</a>
      </article>
    </div>
  </section>

  <section class="panel panel-links">
    <div class="section-heading">
      <p class="eyebrow">Links</p>
      <h2>对外入口保持少、准、直接。</h2>
    </div>
    <div class="contact-links">
      <a class="contact-link" href="/docs/about/personal-profile/">
        <strong>个人介绍</strong>
        <span>查看对外版本与基础信息</span>
      </a>
      <a class="contact-link" href="/docs/">
        <strong>文档目录</strong>
        <span>查看指南、规划和文档入口</span>
      </a>
      <a class="contact-link" href="https://github.com/gengafdafd">
        <strong>GitHub</strong>
        <span>查看项目与代码仓库</span>
      </a>
    </div>
  </section>

  <section class="panel panel-clean">
    <div class="section-heading">
      <p class="eyebrow">Recent Writing</p>
      <h2>让首页直接带出最新内容，而不是只停留在自我介绍。</h2>
    </div>
    <div class="blog-feed">
      {
        recentPosts.map((post) => (
          <article class="blog-card blog-card-feature">
            <p class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</p>
            <h3>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <a class="text-link" href={`/blog/${post.id}/`}>阅读全文</a>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
