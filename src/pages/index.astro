---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="yyyyang | Personal Site"
  description="yyyyang 的个人主页，展示个人介绍、方向、项目入口和长期积累。"
>
  <Fragment slot="hero">
    <div class="hero-grid hero-grid-home hero-grid-minimal">
      <div class="hero-copy hero-copy-home hero-copy-minimal">
        <p class="eyebrow">Personal Site / Writing / Projects</p>
        <h1>简洁一点，留下真正重要的内容。</h1>
        <p class="lead lead-wide">
          yyyyang 的个人主页与博客入口。这里用更克制的方式承载个人介绍、项目、写作和长期积累。
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="/blog/">进入博客</a>
          <a class="button button-secondary" href="/docs/about/personal-profile/">关于我</a>
        </div>
      </div>

      <div class="hero-minimal-note">
        <span class="mini-label">Now</span>
        <p>持续建设个人主页、博客系统与内容结构。</p>
      </div>
    </div>
  </Fragment>

  <section class="panel panel-ghost metrics-panel">
    <div class="metrics-grid metrics-grid-minimal">
      <article class="metric-item">
        <span>Identity</span>
        <strong>Personal Home</strong>
      </article>
      <article class="metric-item">
        <span>Writing</span>
        <strong>Blog</strong>
      </article>
      <article class="metric-item">
        <span>Domain</span>
        <strong>yyyyang.cn</strong>
      </article>
    </div>
  </section>

  <section class="panel accent panel-showcase">
    <div class="section-heading">
      <p class="eyebrow">Sections</p>
      <h2>主页和博客，各自做一件事。</h2>
    </div>
    <div class="grid split-grid showcase-grid">
      <article class="card showcase-card">
        <span class="tag">Home</span>
        <h3>个人主页</h3>
        <p>负责定位、介绍和对外入口。</p>
        <a class="text-link" href="/docs/about/personal-profile/">进入介绍</a>
      </article>
      <article class="card showcase-card">
        <span class="tag">Blog</span>
        <h3>博客</h3>
        <p>负责文章、笔记和长期沉淀。</p>
        <a class="text-link" href="/blog/">进入博客</a>
      </article>
    </div>
  </section>

  <section class="panel panel-links">
    <div class="section-heading">
      <p class="eyebrow">Links</p>
      <h2>保留少量但清楚的入口。</h2>
    </div>
    <div class="contact-links">
      <a class="contact-link" href="/docs/about/personal-profile/">
        <strong>个人介绍</strong>
        <span>查看对外版本与基础信息</span>
      </a>
      <a class="contact-link" href="/docs/">
        <strong>文档目录</strong>
        <span>查看指南、规划和文档入口</span>
      </a>
      <a class="contact-link" href="https://github.com/gengafdafd">
        <strong>GitHub</strong>
        <span>查看项目与代码仓库</span>
      </a>
    </div>
  </section>

  <section class="panel panel-clean">
    <div class="section-heading">
      <p class="eyebrow">Recent Writing</p>
      <h2>最近更新</h2>
    </div>
    <div class="blog-feed">
      {
        recentPosts.map((post, index) => (
          <article class={`blog-card blog-card-feature ${index === 0 ? "blog-card-primary" : ""}`}>
            <div class="blog-cover">
              <span class="chip">Writing</span>
            </div>
            <p class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</p>
            <h3>
              <a href={`/blog/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div class="blog-card-footer">
              <span class="chip">Latest</span>
              <a class="text-link" href={`/blog/${post.id}/`}>阅读全文</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="panel accent">
    <div class="section-heading">
      <p class="eyebrow">Projects</p>
      <h2>几个当前正在建设的方向。</h2>
    </div>
    <div class="projects-grid">
      <article class="project-card">
        <span class="tag">Site</span>
        <h3>个人站点建设</h3>
        <p>围绕 GitHub Pages、Astro、内容结构和视觉风格，把这个站点逐步做成一个长期可维护的个人空间。</p>
      </article>
      <article class="project-card">
        <span class="tag">Writing</span>
        <h3>博客系统与持续更新</h3>
        <p>博客部分已经从 Markdown 文件展示切到真正的静态站页面，后续重点是扩展内容和专题。</p>
      </article>
      <article class="project-card">
        <span class="tag">Identity</span>
        <h3>个人品牌表达</h3>
        <p>通过统一的 logo、导航、主页和博客，慢慢建立稳定的个人识别方式。</p>
      </article>
      <article class="project-card">
        <span class="tag">Content</span>
        <h3>内容系统搭建</h3>
        <p>通过 Astro 内容集合组织文章和文档，让后续写作和展示都变得稳定可维护。</p>
      </article>
      <article class="project-card">
        <span class="tag">Workflow</span>
        <h3>发布链路整理</h3>
        <p>清理 GitHub Pages 冲突工作流，统一改为构建产物部署，避免 README 或 404 覆盖站点。</p>
      </article>
      <article class="project-card">
        <span class="tag">Design</span>
        <h3>视觉与信息秩序</h3>
        <p>通过导航、卡片、区块和渐变头图，把站点从“可用”推到“有辨识度”。</p>
      </article>
    </div>
  </section>

  <section class="panel panel-ghost">
    <div class="section-heading">
      <p class="eyebrow">Latest Update</p>
      <h2>当前站点正在持续完善中。</h2>
    </div>
    <div class="update-strip">
      <div class="update-item">
        <span>Visual</span>
        <strong>主题风格已切到更明亮的品牌站方向</strong>
      </div>
      <div class="update-item">
        <span>Blog</span>
        <strong>博客已从 Markdown 文件列表升级为真正页面</strong>
      </div>
      <div class="update-item">
        <span>Brand</span>
        <strong>已加入站点 logo 与统一视觉识别</strong>
      </div>
    </div>
  </section>
</BaseLayout>
