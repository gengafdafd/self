---
import "../styles/global.css";

const { title = "yyyyang", description = "YYYY 的个人主页与博客入口。" } =
  Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="page-backdrop"></div>
    <div class="site-shell">
      <nav class="topbar topbar-shell">
        <a class="brand" href="/">YYYYANG.CN</a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/docs/">Docs</a>
          <a href="https://github.com/gengafdafd">GitHub</a>
        </div>
      </nav>
      <header class="hero hero-shell">
        <slot name="hero" />
      </header>
      <main class="main-shell">
        <slot />
      </main>
      <footer class="footer">
        <p>Hosted on GitHub Pages.</p>
        <p>{new Date().getFullYear()} yyyyang.cn</p>
      </footer>
    </div>
  </body>
</html>
